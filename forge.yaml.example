# forge.yaml — ForgeDock Configuration
#
# Copy this file to forge.yaml in your project root and customize it.
# ForgeDock commands read forge.yaml to replace hardcoded project references
# with your project's actual values.
#
# Usage:
#   cp forge.yaml.example forge.yaml
#   # Edit forge.yaml with your project details
#   # Add forge.yaml to your .gitignore if it contains sensitive paths
#
# Required sections: project, paths, branches
# Optional sections: runtime, agents, repos, project_board, orchestration, pipeline, services, review, verification, deploy, billing, devdocs, adaptive_scripts, learned, attribution

# =============================================================================
# PROJECT (REQUIRED)
# Core identity of your project. Used by all commands that interact with GitHub.
# Commands: work-on, review-pr, orchestrate, issue, milestone, cleanup
# =============================================================================

project:
  # Human-readable project name (used in reports and comments)
  name: "Acme Platform"

  # GitHub organization or username that owns the repository
  # Used as the --owner flag in gh project commands
  owner: "acme-org"

  # GitHub repository name (without the owner prefix)
  # Combined with owner to form GH_REPO: "acme-org/acme-platform"
  repo: "acme-platform"

  # One-line description of what this project does
  # Used in issue templates and pipeline reports
  description: "SaaS platform for automated data processing"

  # Personal GitHub login of the person who controls this project.
  # Used by work-on Phase 1D (correction capture) to filter issue comments
  # for owner-specific correction signals (e.g. "no, use staging not develop").
  #
  # When to set this:
  #   - REQUIRED for org-owned repos: GitHub comment .user.login is always a
  #     personal account (e.g. "mrdubey"), never the org name (e.g. "acme-org").
  #     Without this field, correction capture is silently disabled for org repos.
  #   - Optional for personal repos: omit it and the pipeline will auto-resolve
  #     via `gh api repos/{GH_REPO} --jq '.owner.login'`.
  #
  # Example (org repo owned by "acme-org", controlled by "alice"):
  #   owner_login: "alice"
  # owner_login: "alice"

  # Pipeline repository — optional. Set this if the ForgeDock pipeline itself
  # lives in a different repo than the project being developed.
  # Used by audit.md, audit-agents.md, and security-audit.md to resolve {FORGE_REPO}
  # when looking up pipeline issues, commands, and audit history.
  # If omitted, these commands fall back to project.owner/project.repo.
  # forge_repo: "acme-org/acme-forge"

# =============================================================================
# RUNTIME (OPTIONAL)
# ForgeDock's execution backend. "native" is the recommended local runtime;
# "auto" falls back through compatibility backends when native is unavailable.
# =============================================================================

runtime:
  default: "native"

# =============================================================================
# PATHS (REQUIRED)
# Local filesystem paths. Used by commands that create worktrees and read files.
# Commands: work-on (Phase 3E worktree creation), quality-gate, deploy-info
# =============================================================================

paths:
  # Absolute path to the project root on the local machine
  # This is where `git worktree add` commands are anchored
  root: "/home/youruser/projects/acme-platform"

  # Directory where git worktrees are created for each branch
  # Relative to root, or absolute path
  # Default: "{root}/.forgedock/worktrees"
  worktree_base: "/home/youruser/projects/acme-platform/.forgedock/worktrees"

  # Path to a credentials YAML file for external service authentication
  # Optional — only needed for commands that access analytics, monitoring, etc.
  # File should NOT be committed to version control
  # credentials:
  #   file: "/home/youruser/credentials.yaml"

# =============================================================================
# BRANCHES (REQUIRED)
# Branch naming conventions. Used to determine PR targets and source branches.
# Commands: work-on (PR targeting), review-pr, cleanup
# =============================================================================

branches:
  # Default branch of the repository (usually main or master)
  default: "main"

  # Staging branch name for fast-lane PRs (issues without a milestone)
  # Set to "main" if your project has no staging branch
  staging: "staging"

  # Pattern for feature/milestone branches
  # {slug} is replaced with the milestone title converted to kebab-case
  # Example: milestone "User Auth v2" → "milestone/user-auth-v2"
  feature_pattern: "milestone/{slug}"

# =============================================================================
# AGENTS (OPTIONAL)
# Default model for pipeline agents — the main orchestrator and every
# sub-agent spawned via the Agent/Task tool while following a command spec
# (work-on, orchestrate, review-pr, etc.).
# Commands: all commands with an "Agent model policy" line
# =============================================================================

# agents:
#   # Accepts a short alias: "sonnet", "opus", or "haiku" — the same values
#   # the Agent/Task tool's `model` parameter already accepts. This is the
#   # only form that works for interactive command-spec sub-agent spawning.
#   #
#   # bin/runner.mjs (the headless/CI runner, which calls the Anthropic SDK
#   # directly) also accepts a full Anthropic model ID here as a pass-through
#   # escape hatch (e.g. "claude-opus-4-6") — but a full ID does NOT work for
#   # interactive Agent/Task tool calls, which only accept the short-alias
#   # enum above. Prefer the short alias unless you specifically need a
#   # headless-only override.
#   #
#   # Resolution order (highest precedence first):
#   #   1. --model <id>              (forgedock run CLI flag, headless only)
#   #   2. FORGEDOCK_MODEL env var   (headless runner only)
#   #   3. agents.default_model      (this field)
#   #   4. Hardcoded default         ("sonnet" for interactive agents /
#   #                                 "claude-sonnet-5" for the headless runner)
#   #
#   # Omit this field entirely for no change from today's behavior.
#   default_model: "sonnet"
#
#   # Model override for CHILD sub-agents that a top-level command spawns
#   # internally — e.g. /orchestrate's per-issue /work-on agents, /review-pr's
#   # domain persona reviewers, /analytics's parallel data-collection agents.
#   # This is distinct from `default_model` above, which only governs the
#   # main agent you invoke directly (the one running the command spec).
#   #
#   # Accepts the same short alias as `default_model` ("sonnet"/"opus"/"haiku").
#   #
#   # Resolution order (highest precedence first):
#   #   1. agents.subagent_model     (this field)
#   #   2. agents.default_model      (falls back here if subagent_model is unset)
#   #   3. Hardcoded default         ("sonnet")
#   #
#   # Omit this field to have sub-agents inherit default_model (or "sonnet"
#   # if that's unset too) — no change from today's behavior.
#   subagent_model: "sonnet"

# =============================================================================
# REPOS (OPTIONAL)
# Multi-repo configuration. Used when your project spans multiple repositories.
# Commands: work-on (multi-repo prefix routing), sync-ecosystem
#
# Without this section, all issues are routed to project.owner/project.repo.
# With this section, you can use prefixes like "mcp:5" or "n8n:12" to route
# issues to satellite repositories.
# =============================================================================

# repos:
#   # The default repository (same as project.owner/project.repo)
#   # Issues without a prefix are routed here
#   default:
#     repo: "acme-org/acme-platform"
#     staging_branch: "staging"
#
#   # Satellite repositories, keyed by prefix
#   # Format: "<prefix>:<issue_number>" in work-on commands
#   satellites:
#     - prefix: "mcp"
#       repo: "acme-org/acme-mcp-server"
#       staging_branch: "main"
#       local_path: "/home/youruser/projects/acme-mcp-server"
#
#     - prefix: "sdk"
#       repo: "acme-org/acme-python-sdk"
#       staging_branch: "main"
#       local_path: "/home/youruser/projects/acme-python-sdk"
#       # Set billing_enabled: true to run Phase 4 (Financial Integrity) of
#       # /security-audit against this satellite repo. Mirrors the top-level
#       # billing.enabled flag but scoped per-satellite.
#       # billing_enabled: false
#
#     # Monorepo satellite: multiple packages in a single repo.
#     # Use subpaths to name each package root relative to local_path.
#     # /sync-ecosystem uses these to locate per-package version files and
#     # publish workflows when syncing API changes across SDK packages.
#     - prefix: "mono"
#       repo: "acme-org/acme-sdks"
#       staging_branch: "main"
#       local_path: "/home/youruser/projects/acme-sdks"
#       subpaths:
#         python_sdk: "sdk/python"
#         node_sdk: "sdk/node"

# =============================================================================
# PROJECT BOARD (OPTIONAL)
# GitHub Projects (v2) integration. Used to track issue workflow state on the
# project board automatically as issues move through the pipeline.
# Commands: work-on (Phase 0C sync, Phase 6B update), orchestrate
#
# To find your project_id and field IDs:
#   gh project list --owner <owner>
#   gh project field-list <project_number> --owner <owner>
# =============================================================================

# project_board:
#   # GitHub organization or username that owns the project board
#   owner: "acme-org"
#
#   # Project number (visible in the URL: /projects/1)
#   project_number: 1
#
#   # GraphQL node ID of the project (PVT_... format)
#   # Run: gh project list --owner <owner> --format json | jq '.projects[] | {number, id}'
#   project_id: "PVT_kwHOxxxxxxxxxxxxxxxx"
#
#   # GitHub Projects field IDs (PVTSSF_... format)
#   # Run: gh project field-list <number> --owner <owner> --format json
#   field_ids:
#     status: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     lane: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     component: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     priority: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     workflow: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#
#   # Single-select option IDs for each field
#   # Run: gh project field-list <number> --owner <owner> --format json --jq '.fields[]'
#   option_ids:
#     status:
#       todo: "xxxxxxxx"
#       in_progress: "xxxxxxxx"
#       done: "xxxxxxxx"
#
#     lane:
#       fast: "xxxxxxxx"
#       feature: "xxxxxxxx"
#       sync: "xxxxxxxx"
#
#     priority:
#       p0: "xxxxxxxx"
#       p1: "xxxxxxxx"
#       p2: "xxxxxxxx"
#       p3: "xxxxxxxx"
#
#     workflow:
#       investigating: "xxxxxxxx"
#       building: "xxxxxxxx"
#       in_review: "xxxxxxxx"
#       merged: "xxxxxxxx"
#
#   # Component options map repo identifiers to option IDs
#   # Used to set the Component field when an issue is added to the board
#   components:
#     - repo: "acme-org/acme-platform"
#       option_id: "xxxxxxxx"
#       label: "Platform"
#     - repo: "acme-org/acme-mcp-server"
#       option_id: "xxxxxxxx"
#       label: "MCP Server"

# =============================================================================
# ORCHESTRATION (OPTIONAL)
# Concurrency limits and cascade admission policy for the /orchestrate batch
# engine. `max_concurrent` already existed at runtime but was undocumented
# anywhere prior to forge#2234; `cascade` is the new admission-policy config
# surface (forge#2234) — see docs/CONFIG.md → `orchestration` for full field
# docs and the preset table (all / balanced / conservative).
# Commands: orchestrate
# =============================================================================

# orchestration:
#   # Maximum number of /work-on sub-agents dispatched concurrently. Guards
#   # against saturating the Anthropic API rate limit in one burst on a large
#   # ready set. Default: 12.
#   max_concurrent: 12
#
#   cascade:
#     # Named preset — "all" (pick up everything, no caps, no heuristics),
#     # "balanced" (default, matches pre-#2234 hardcoded behavior exactly), or
#     # "conservative" (same shape as balanced, lower token ceiling). Any
#     # granular key below overrides just that field on top of the preset.
#     policy: "balanced"
#
#     # Max cascade generation admitted at Phase 1 resolve time (the
#     # `cascade`/`review-findings`/`findings` resolution). Generation 1 = an
#     # original issue; generation 2 = spawned from a review-finding;
#     # generation 3 = spawned from a finding spawned from a review-finding;
#     # etc. Accepts a positive integer or "unlimited". This is what makes
#     # "admit gen-2, stop at gen-3" expressible — the pre-#2234 --allow-gen2
#     # CLI flag was all-or-nothing and could not say that. Does NOT relax
#     # Step 4C's absolute autonomous mid-run cascade defer (unaffected by
#     # this key regardless of value). Default: 1.
#     max_generation: 1
#
#     # Per-batch token ceiling for Step 4C's review-finding cascade dispatch.
#     # New home for the same lever previously read only via the deprecated
#     # pipeline.token_budget_per_batch alias below (still honored when this
#     # key is absent). Accepts a positive integer or "unlimited". Default:
#     # 900000.
#     token_budget: 900000
#
#     # Suppress cascade-finding dispatch once the original batch is fully
#     # human-gated (forge#1814's BATCH_FULLY_GATED). Default: true.
#     defer_on_batch_gated: true
#
#     # Defer P3-and-below findings whose title contains "comment"/"typo".
#     # Default: true.
#     keyword_heuristic: true
#
#     # Defer a P3 finding that shares a file with the active batch. Default: true.
#     p3_same_file_defer: true
#
# NOTE: safety exclusions (security/billing/anti-bot/auth findings) are never
# batched or auto-admitted by ANY cascade.policy, including "all" — that
# exclusion is a hard invariant enforced upstream of this section, not a
# configurable key.

# =============================================================================
# PIPELINE (OPTIONAL)
# Tuning knobs for the /orchestrate batch engine — stall detection and the
# review-finding cascade-control token budget. All keys optional; sane
# defaults apply when omitted (read via `yq '.pipeline.KEY // default'`).
# Commands: orchestrate
# =============================================================================

# pipeline:
#   # Minutes an agent may sit idle (no FORGE:HEARTBEAT / label change) before
#   # /orchestrate's Step 4B.5 stall detector treats it as stuck and attempts
#   # an auto-resume. Default: 15.
#   stall_timeout_minutes: 15
#
#   # DEPRECATED — use orchestration.cascade.token_budget instead (forge#2234).
#   # Kept working as an alias so existing configs are unaffected; when both
#   # are set, orchestration.cascade.token_budget wins.
#   #
#   # Per-batch token ceiling for /orchestrate's Step 4C review-finding cascade
#   # control. Distinct from the `--budget N` dollar-cost flag (economic
#   # scheduling, forge#1743): that mechanism is opt-in, dollar-denominated, and
#   # gates the *original* issue dispatch order. This ceiling is always-on,
#   # token-denominated, and scopes ONLY to Step 4C's cascade dispatch of
#   # review-finding issues spawned mid-batch. P1/P2 findings are NEVER gated by
#   # this budget — only P3-and-below dispatch volume is reduced once the
#   # ceiling is approached; additional findings defer to the Step 4F
#   # Completion Sweep instead of spawning more individual /work-on pipelines.
#   # Default: 900000 (sized for ~6 average P3 pipelines at the estimate below).
#   token_budget_per_batch: 900000
#
#   # Estimated token cost of a single P3-or-lower review-finding /work-on
#   # pipeline, used to decrement token_budget_per_batch above. There is no
#   # live per-agent token telemetry to read yet (see commands/audit-agents.md,
#   # which tracks idle%/active-time/resumes, not token counts) — this is a
#   # fixed estimate, not a measurement. A same-run surface-area-clubbed batch
#   # issue (forge#1818) is charged this estimate ONCE for the whole cluster,
#   # not once per member finding. Default: 150000 (midpoint of the commonly
#   # observed 75k-260k token range for a single P3 review-finding pipeline).
#   token_estimate_per_finding: 150000
#
#   # Narration verbosity for /orchestrate Step 4B per-completion status updates.
#   #   "terse"   (default when unset) — one line per completion only, e.g.
#   #             "✓ #123 — {title} → PR #456 merged to staging". No recap
#   #             table is printed between completions. Matches today's
#   #             existing behavior — setting this explicitly is a no-op.
#   #   "verbose" — same one-liners, plus a running per-completion recap table
#   #             (issue, title, PR, target, elapsed). Useful when babysitting
#   #             a batch interactively; noisier for long unattended runs.
#   # This setting is cosmetic only — it never changes which phases run or
#   # what gets committed. The Step 6B consolidated report (Implementation
#   # Results, Review-Spawned Issues, Batch Trajectory Analytics — full tables)
#   # always renders in full exactly once at the end, regardless of this value.
#   narration: "terse"

# =============================================================================
# SERVICES (OPTIONAL)
# External service URLs and identifiers. Used by analytics, monitoring, and
# GEO audit commands.
# Commands: analytics, geo-audit, autopilot (analytics snapshot)
# =============================================================================

# services:
#   # Primary domain of the project's public-facing site
#   domain: "acme.io"
#
#   # Google Search Console property (full URL or domain: prefix)
#   gsc_property: "https://acme.io"
#
#   analytics:
#     # Umami self-hosted analytics
#     umami:
#       url: "https://umami.acme.io"
#       # Website ID from Umami dashboard
#       website_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
#     # Microsoft Clarity
#     clarity:
#       project_id: "xxxxxxxxxx"
#
#     # Persistent audit history file (YAML list of past audit snapshots)
#     # Written by /analytics after each run; read by Phase 0 for trend baselines
#     # Should be outside the repo — do not commit
#     # history_file: "/home/youruser/analytics-history.yaml"
#
#     # Google Analytics 4
#     ga4:
#       # GA4 property ID (numeric, from GA4 dashboard → Admin → Property Details)
#       property_id: "000000000"
#       # Path to a GA4 service account JSON key file
#       # Grant this service account Viewer access in GA4 → Admin → Account Access Management
#       # File should NOT be committed to version control
#       # service_account_key: "/home/youruser/credentials/ga4-service-account.json"
#
#   # Frontend app URL used by qa-sweep for page accessibility testing
#   # Default: http://localhost:3000 — override for non-localhost deployments
#   app_url: "https://acme.io"
#
#   # API base URL for health checks and endpoint verification
#   api_url: "https://api.acme.io"
#
#   # SSH target for production server health checks run by /autopilot
#   # Format: user@host — e.g., ubuntu@203.0.113.42
#   # Used in Phase 1 (SSH health check) of the autopilot cycle
#   # Optional — omit if autopilot does not need server-level checks
#   # server_ssh: "ubuntu@203.0.113.42"
#
#   # Absolute path on the production server to open eMemo files
#   # Used by /autopilot to surface in-progress work notes from the server
#   # Optional — only relevant if your team uses eMemo
#   # ememo_path: "/home/ubuntu/ememo"

# =============================================================================
# REVIEW (OPTIONAL)
# Context provided to review agents when they audit PRs.
# Commands: review-pr, review-pr-agents (all domain agents)
# =============================================================================

# review:
#   # Tech stack description — injected into review agent prompts
#   # Be specific: framework versions, DB engines, hosting environment
#   tech_stack: "Next.js 15 App Router, FastAPI, PostgreSQL 16, Docker, Traefik"
#
#   # Additional context for reviewers
#   # What makes this codebase unusual? What pitfalls exist?
#   context: |
#     Multi-service monorepo: services/api (Python/FastAPI), web/ (Next.js).
#     Deploy: blue/green via Docker Compose on a single VPS behind Traefik.
#     Database: PostgreSQL with async SQLAlchemy. No ORM migrations — raw SQL.
#
#   # Domain-specific review notes (keyed by review-pr-agents domain).
#   # Each key injects free-text context into the matching review agent's [DOMAIN_CONTEXT].
#   # If a key is absent, the agent falls back to generic checks without project conventions.
#   #
#   # Special gating rule: the `scraping` key also GATES the Scraper agent — the agent
#   # only spawns when this key is present. Projects using Playwright for E2E tests only
#   # (no web-scraping domain) must NOT set this key.
#   domains:
#     auth: "JWT + refresh token rotation; sessions stored in Redis; all admin endpoints require ADMIN_SECRET"
#     billing: "Stripe webhooks; idempotency keys required on all handlers; reconciliation in worker/reconcile.py"
#     concurrency: "Redis for distributed locks; use with_for_update() on all balance reads; job queue is Celery"
#     database: "Always use docker exec <container> for psql/migrations; Alembic for schema versioning"
#     infra: "Blue/green deploy via Docker Compose; deploy workflow: .github/workflows/deploy.yml; secrets via SOPS"
#     frontend: "Next.js 15 App Router; shadcn/ui components; all server actions must validate auth"
#     security: "Internal services reachable at 10.0.0.x; Redis not firewalled from workers"
#     api: "FastAPI; all routers registered in app/main.py; Pydantic v2 for validation"
#     # scraping: "Browser pool in worker/browser/pool.py; tier escalation in worker/consumers/scrape.py"
#     # ^^^ Uncomment scraping only if this project has a web-scraping domain.
#     # ^^^ Leaving it commented out prevents the Scraper agent from spawning on Playwright E2E PRs.
#
#   # Provenance-based trust escalation (forge#1745).
#   # Controls the 30-day shadow-mode window before enforcement begins.
#   #
#   # "true"  (default) — shadow mode: intensity tier is computed and logged in the FORGE:REVIEW
#   #           annotation, but the agent roster is NOT modified. Use this during the initial
#   #           30-day calibration window so the provenance table can accumulate data.
#   # "false" — enforcement mode: the computed intensity tier DOES modify the agent roster
#   #           (PROVEN cells may drop optional judgment agents; NOVEL cells escalate to full panel).
#   #           Set this after the 30-day shadow window once the provenance table is trusted.
#   #
#   # trust_shadow_mode: "true"
#
#   # Domain-to-file mapping used by /work-on investigation and /review-pr agents
#   # to quickly locate relevant files for a given issue domain.
#   # Keys match issue label domain names; values are lists of file path patterns
#   # (relative to repo root, glob-style). Optional — if omitted, agents infer
#   # relevant files from issue labels and the Affected Files section instead.
#   # key_paths:
#   #   auth: ["services/api/auth/**", "web/src/lib/auth/**"]
#   #   billing: ["services/api/billing/**", "web/src/app/billing/**"]
#   #   database: ["services/api/db/**", "migrations/**"]
#
#   # Layout paths used by pipeline commands for file discovery and classification.
#   # These drive /qa-sweep page discovery, /deploy-info file categorization,
#   # /orchestrate high-fan-in detection, /review-pr route-registration checks,
#   # and the verify-route-registration.sh script. All values are relative to
#   # the repository root. Defaults match the example monorepo layout — set
#   # these if your project uses a different directory structure.
#   #
#   # layout:
#   #   # Root directory of Next.js App Router pages (contains page.tsx / page.js files).
#   #   # Used by /qa-sweep to discover pages. Agent fails loudly if zero pages are
#   #   # found here and this key is not set.
#   #   pages: "web/src/app"
#   #
#   #   # Root directory of the backend API service.
#   #   # Used by /deploy-info file categorization and /review-pr integration checks.
#   #   api: "services/api"
#   #
#   #   # Directory containing FastAPI router modules (.py files).
#   #   # Used by /review-pr and verify-route-registration.sh to check router registration.
#   #   api_routers: "services/api/app/routers"
#   #
#   #   # Path to the API application entrypoint (router/middleware registration).
#   #   # High-fan-in file: /orchestrate serializes any issue that touches this file.
#   #   api_main: "services/api/app/main.py"
#   #
#   #   # Directory containing API middleware modules.
#   #   # Used by /review-pr and verify-route-registration.sh.
#   #   api_middleware: "services/api/app/middleware"
#   #
#   #   # Root directory of the background worker service.
#   #   # Used by /deploy-info file categorization and /orchestrate high-fan-in detection.
#   #   worker: "services/worker"
#   #
#   #   # Path to the worker service entrypoint (task registration, consumer setup).
#   #   # High-fan-in file: /orchestrate serializes any issue that touches this file.
#   #   worker_main: "services/worker/worker/main.py"
#   #
#   #   # Directory containing database migration files.
#   #   # Used by /deploy-info to detect and list migration changes.
#   #   migrations: "infra/migrations"
#   #
#   #   # Root directory of shared frontend component library.
#   #   # Used by verify-route-registration.sh to check component import coverage.
#   #   frontend_components: "web/src/components"

# =============================================================================
# VERIFICATION (OPTIONAL)
# Service health-check patterns for the quality gate and validate commands.
# Commands: quality-gate, validate
# =============================================================================

# verification:
#   # HTTP endpoint that returns 200 when the service is healthy
#   health_endpoint: "https://api.acme.io/health"
#
#   # Patterns to verify in the health response body
#   health_patterns:
#     - '"status": "ok"'
#     - '"database": "connected"'
#
#   # Services to check as part of deployment verification
#   services:
#     - name: "api"
#       container: "acme-api-blue"
#       health_url: "http://localhost:8000/health"
#     - name: "web"
#       container: "acme-web-blue"
#       health_url: "http://localhost:3000"
#
#   # Project-specific service name prefixes that identify internal services
#   # in shell scripts (curl/wget calls). Used by verify-host-headers.sh via
#   # the FORGE_INTERNAL_PATTERNS env var. Values are joined with | and appended
#   # to the generic defaults (localhost, 127.0.0.1, api-, worker-, 172.x, IP vars).
#   # Add your project's container/service name prefixes here so that curl calls
#   # to those services are checked for explicit Host headers.
#   # Example: if your services are named "acme-api", "acme-worker", add "acme-"
#   internal_service_patterns:
#     - "acme-"
#
#   # Toolchain commands for lint, format, typecheck, test, and build steps.
#   # Used by: review-pr, review-pr-staging, work-on (Phase 3H, validate), rollback,
#   #          incident-response, orchestrate (integration build gate).
#   #
#   # Declare your project's actual toolchain here once. Pipeline stages read these
#   # values and run your commands directly — they never assume poetry/npm/tsc.
#   # When a key is absent or empty, the stage logs "SKIPPED — not configured in
#   # verification.commands" and continues without failing. This means you can adopt
#   # the schema incrementally: add only the steps your project actually uses.
#   #
#   # Each command is a shell string run from the repository root (or the worktree
#   # root). Use relative paths or rely on $PATH. Commands may include flags.
#   #
#   # Language keys are arbitrary identifiers — name them after your stack.
#   # Common keys: python, typescript, go, rust, java, node
#   #
#   # commands:
#   #   # Python project using ruff + pytest
#   #   python:
#   #     format: "ruff format --check ."
#   #     lint: "ruff check ."
#   #     typecheck: "mypy src/ --ignore-missing-imports"
#   #     test: "pytest tests/ -x -q --tb=short"
#   #     build: ""   # omit or leave empty to skip
#   #
#   #   # TypeScript project using tsc + vitest
#   #   typescript:
#   #     format: "prettier --check \"src/**/*.{ts,tsx}\""
#   #     lint: "eslint src/"
#   #     typecheck: "tsc --noEmit"
#   #     test: "vitest run"
#   #     build: "npm run build"
#   #
#   #   # Go project
#   #   go:
#   #     format: "gofmt -l ."
#   #     lint: "golangci-lint run"
#   #     typecheck: ""   # Go compilation is the typecheck — set build instead
#   #     test: "go test ./..."
#   #     build: "go build ./..."
#   #
#   #   # Rust project
#   #   rust:
#   #     format: "cargo fmt --check"
#   #     lint: "cargo clippy -- -D warnings"
#   #     typecheck: ""
#   #     test: "cargo test"
#   #     build: "cargo build"
#
#   # Known-slow / hanging test suites to skip or narrow during automated pipeline
#   # runs. Some test files make live network/LLM calls or otherwise hang far
#   # longer than a normal unit-test pass — without this list, /work-on Phase 3H
#   # (and any `learned.test_commands` entry) will re-launch the full hanging
#   # suite on every pass, and each stall-triggered resume reloads full context.
#   #
#   # Each entry's `pattern` is matched as a substring against the full command
#   # text (e.g. "pytest tests/test_agents.py -x -q") — not just a bare filename.
#   # Exactly one of `skip` or `subset` should be set per entry:
#   #   skip: true       — the matched command is skipped entirely (logged, not run)
#   #   subset: "<cmd>"  — the matched command is replaced with this safe-subset
#   #                      command instead of running the full command
#   # `reason` is free text surfaced in the skip/substitution log line.
#   #
#   # Default: [] (no known-slow tests configured — all commands run unchanged,
#   # same as today's behavior). This is additive and fully backward compatible —
#   # repos that don't set this field see no behavior change.
#   # Used by: work-on (Phase 3H, before running learned.test_commands)
#   #
#   # known_slow_tests:
#   #   - pattern: "test_agents.py"
#   #     reason: "Makes real network/LLM calls — hangs pipeline agents waiting on live responses"
#   #     skip: true
#   #   - pattern: "test_integration.py"
#   #     reason: "Full suite requires a live DB; subset covers unit-safe cases only"
#   #     subset: "pytest tests/test_integration.py -k 'not live_db' -x -q"
#
#   # Integration test suites run by /test-gate against the provisioned cluster.
#   # Each entry specifies a logical cluster (matched to test_services), the shell
#   # command to execute, and the working directory (relative to project root).
#   # Used by: test-gate (Phase 3 — Provision + Phase 4 — Fan out)
#   #
#   # integration_tests:
#   #   - cluster: "api"
#   #     command: "pytest tests/integration/ -q --tb=short"
#   #     working_dir: "."
#   #   - cluster: "worker"
#   #     command: "pytest tests/worker/ -q --tb=short"
#   #     working_dir: "."
#
#   # Maps logical cluster names (from integration_tests[].cluster) to running
#   # container names. /test-gate uses these to verify the cluster is live before
#   # executing the test command. Omit entries for clusters that do not use Docker.
#   # Used by: test-gate (Phase 3 — Provision)
#   #
#   # test_services:
#   #   api: "acme-api-blue"
#   #   worker: "acme-worker-blue"
#
#   # Controls /test-gate posture at the staging-to-main deploy boundary.
#   # posture:
#   #   blocking  — a BLOCK verdict prevents the merge (override_phrase bypasses).
#   #   advisory  — a BLOCK verdict is surfaced in the summary but does not block.
#   # override_phrase — exact string an operator must include in a PR comment to
#   #   bypass a blocking BLOCK verdict (mirrors the Phase 0A open-finding gate).
#   # Defaults: posture: "blocking", override_phrase as shown below.
#   # Used by: test-gate (Phase 7 — Verdict), review-pr-staging (Phase 6.5)
#   #
#   # test_gate:
#   #   posture: "blocking"
#   #   override_phrase: "OVERRIDE: shipping with test failures —"

# =============================================================================
# DEPLOY (OPTIONAL)
# Deployment model configuration. Used by deploy-info, incident-response,
# rollback, and work-on to trigger and verify deploys without hardcoding
# workflow names, secrets chains, or container naming conventions.
# Commands: deploy-info, incident-response, rollback, work-on (Phase 3J)
# =============================================================================

# deploy:
#   # Filename of the GitHub Actions workflow used to trigger deploys.
#   # Referenced as: gh workflow run {deploy.workflow} --ref {branch} -f ...
#   # Set to "" or omit to skip workflow-trigger steps (CI/CD deploys automatically).
#   # Example: "hotfix-deploy.yml", "deploy.yml", "release.yml"
#   workflow: "hotfix-deploy.yml"
#
#   # Input parameter names for the deploy workflow.
#   # Keys are semantic names used by pipeline commands; values are the actual
#   # workflow_dispatch input names declared in the workflow file.
#   # Omit fields whose workflow does not declare the corresponding input.
#   workflow_inputs:
#     # Which services to rebuild/restart (comma-separated or "all")
#     services: "services"
#     # Human-readable deploy reason logged by the workflow
#     reason: "reason"
#
#   # Secrets backend used to deliver runtime secrets to containers.
#   # Controls which secret-chain checks run in work-on (Phase 3J) and deploy-info.
#   # Values:
#   #   sops     — Mozilla SOPS + decrypt-secrets.sh → .env.production chain
#   #   aws-sm   — AWS Secrets Manager (verification steps skipped — configure separately)
#   #   vault    — HashiCorp Vault (verification steps skipped — configure separately)
#   #   ci-env   — Secrets injected directly by CI/CD runner environment variables
#   #   none     — No secrets backend; all vars are operator-set in .env.production
#   # Default: none (all secret-chain checks are skipped with an explicit log message)
#   secrets_backend: "sops"

# =============================================================================
# AUTOPILOT (OPTIONAL)
# Configuration for the /autopilot autonomous deploy loop.
# Commands: autopilot
# =============================================================================

# autopilot:
#   # Label used to identify the rolling ops issue where FORGE:AUTOPILOT_CYCLE
#   # annotations accumulate. The ops issue is created automatically on first run
#   # if no open issue with this label exists.
#   # Default: "autopilot-ops"
#   ops_issue_label: "autopilot-ops"
#
#   # Declared autonomy policy — controls unattended (headless) operation.
#   # When headless: false (default), /autopilot with --fix refuses to dispatch
#   # any fixes and explains why. Autonomy is opt-in per repo.
#   #
#   # headless: false   # explicit opt-in to unattended fixing; default: false
#
#   # Per-priority approval map — evaluated when headless: true.
#   # Each priority maps to one of two actions:
#   #   auto        — dispatch the fix autonomously
#   #   needs-human — post the fix plan on the ops issue for async approval; never dispatch
#   # Default for all priorities: needs-human (conservative)
#   #
#   # approve:
#   #   p0: needs-human   # P0s are never autonomous — always gate
#   #   p1: needs-human   # P1s require human approval
#   #   p2: auto          # P2s are safe to auto-approve in unattended runs
#   #   p3: auto          # P3s are safe to auto-approve in unattended runs
#
#   # Budget ceilings — enforced per cycle; cycle stops dispatching when hit.
#   # per_cycle_fixes: max number of issues dispatched as fixes in one cycle.
#   #   When reached, remaining eligible issues are deferred to the next cycle
#   #   with a deferral report in the FORGE:AUTOPILOT_CYCLE annotation.
#   # per_cycle_tokens: advisory spend cap (null = unlimited).
#   #   Enforceable once #1743 (token accounting) is merged. Until then, treated
#   #   as documentation-only; no runtime enforcement.
#   #
#   # budget:
#   #   per_cycle_fixes: 3     # FIX_LIMIT ceiling; null or omit for unlimited
#   #   per_cycle_tokens: null # optional hard spend cap (future enforcement via #1743)
#
#   # Recon sources — which collectors run during Phase 1 (Recon).
#   # Values: ci (CI/CD health), backlog (issue backlog health)
#   # Default: [ci, backlog] (both run)
#   #
#   # recon_sources: [ci, backlog]

# =============================================================================
# BILLING (OPTIONAL)
# Controls whether financial integrity checks run in security-audit.md.
# Only relevant if your project uses Stripe or similar billing infrastructure.
# Commands: security-audit (Phase 4 — Financial Integrity)
# =============================================================================

# billing:
#   # Set to true to enable Phase 4 (Financial Integrity) in /security-audit.
#   # When false (default), the billing audit phase is skipped — appropriate for
#   # projects that do not process payments or have no Stripe integration.
#   enabled: false

# =============================================================================
# DEVDOCS (OPTIONAL)
# Path configuration for the devdocs knowledge tree scaffolded by
# `npx forgedock docs init`. Pipeline agents (work-on, review-pr, etc.) read
# these files as authoritative project knowledge before acting.
# Commands: docs init
# =============================================================================

# devdocs:
#   # Path to the devdocs knowledge tree, relative to the project root.
#   # Default: "devdocs" — creates devdocs/ in the project root.
#   # Run `npx forgedock docs init` to scaffold the tree from seed templates.
#   path: "devdocs"
#
#   # Migration note: if you previously stored project context in
#   # forge.yaml → review.context, move that content into the appropriate
#   # devdocs file:
#   #   - Architecture decisions  → devdocs/project/architecture.md
#   #   - Tech stack details      → devdocs/project/stack.md
#   #   - Coding conventions      → devdocs/project/conventions.md
#   #   - Project terminology     → devdocs/project/glossary.md
#   #   - ForgeDock usage notes   → devdocs/agent/using-forgedock.md
#   # Agents read devdocs/ files as binding source-of-truth, so they receive
#   # richer context than the single review.context string.

# =============================================================================
# ADAPTIVE_SCRIPTS (OPTIONAL)
# Per-repo scripts that ForgeDock generates and updates as it learns your
# project's patterns. These scripts live in .forgedock/scripts/ and take
# precedence over universal scripts shipped with ForgeDock.
#
# The directory is scaffolded automatically by `npx forgedock init` and is
# gitignored by default. Remove the .forgedock/scripts/ line from .gitignore
# to commit scripts to version control and share them with your team.
#
# Commands: work-on (script discovery), optimize (script generation — #668)
# =============================================================================

# adaptive_scripts:
#   # Enable or disable per-repo adaptive scripts.
#   # When false, pipeline agents use only universal scripts shipped with ForgeDock.
#   # Default: true
#   enabled: true
#
#   # Directory where per-repo scripts are stored, relative to the project root.
#   # Scaffolded by `npx forgedock init` if it doesn't exist.
#   # Default: ".forgedock/scripts"
#   directory: ".forgedock/scripts"
#
#   # Whether per-repo scripts are committed to version control.
#   # false (default): .forgedock/scripts/ is gitignored — scripts are local only
#   # true: remove .forgedock/scripts/ from .gitignore to share scripts with your team
#   # To opt in: remove the .forgedock/scripts/ entry from .gitignore
#   commit: false
#
#   # gate.d/ — learned quality-gate checks (Tier-A mechanizable patterns)
#   #
#   # Scripts placed in <directory>/gate.d/ are executed by /quality-gate after
#   # the built-in domain checks and the static check-registry (Step 2R). They
#   # run on every quality-gate invocation when adaptive_scripts.enabled is true.
#   #
#   # CONTRACT:
#   #   Input:   $1 = absolute path to the unified diff file (git diff HEAD)
#   #            $2 = absolute path to the worktree root
#   #   Output:  findings lines on stdout, one per line, in the standard format:
#   #              SLUG | HIGH|MEDIUM|LOW | FILE | MESSAGE
#   #            (e.g.  GATD-stderr-contamination | HIGH | scripts/doctor.sh | ...)
#   #   Exit codes:
#   #     0  — no findings / check passed (stdout may be empty)
#   #     1  — one or more findings emitted on stdout
#   #     2  — check is inapplicable to this diff (skip silently)
#   #   Timeout: 30 seconds per script, enforced by quality-gate.
#   #            Timeout is treated as a HIGH finding (fail-closed).
#   #
#   # Promotion: /optimize Phase 5 drafts gate.d scripts when a pattern reaches
#   # ≥3 validated occurrences in the Forge Ledger. Scripts arrive as a PR for
#   # human review before enforcement — they are never silently auto-enforced.
#   #
#   # Example gate.d script (checks for stderr contamination in doctor scripts):
#   #   #!/usr/bin/env bash
#   #   # gate.d/stderr-contamination.sh
#   #   # Flags 'command 2>&1' patterns in doctor/*.sh (contaminates stdout health output)
#   #   DIFF_PATH="$1"
#   #   grep -n '2>&1' "$DIFF_PATH" | grep -E '^[+][^+].*doctor' | while IFS= read -r line; do
#   #     echo "GATD-stderr-contamination | HIGH | (diff) | 2>&1 in doctor script contaminates stdout"
#   #     exit 1
#   #   done

# =============================================================================
# LEARNED (OPTIONAL)
# Agent-writable section for project-specific patterns captured across sessions.
# Pipeline agents read this section at startup (Phase 0B) and use it to override
# default routing decisions and toolchain commands. Agents write to this section
# when they detect correction signals in owner comments (Phase 1D).
#
# You can also edit this section manually after reviewing what agents have learned.
#
# All keys are optional — omit any key to use the pipeline default.
# Commands: work-on (Phase 0B reads; Phase 1D writes)
# =============================================================================

# learned:
#   # Branch target overrides — keyed by branch role, value is the actual branch name.
#   # These override branches.staging and similar fields when present.
#   # Example: if your project uses "develop" as the integration branch instead of "staging":
#   branch_targets:
#     staging: "develop"        # overrides branches.staging for fast-lane PR targeting
#
#   # Custom test commands to run during Phase 3H (validate) in addition to
#   # verification.commands entries. Appended to the verification step, not replaced.
#   # Use when the agent has learned repo-specific pre-PR checks:
#   test_commands:
#     - "pnpm typecheck"        # run before PR
#     - "pnpm test --run"
#
#   # Test location hints — overrides default assumption of tests/ directory.
#   # Used by Phase 3F to locate tests when writing or updating test files:
#   test_locations:
#     - "__tests__/"            # actual test directory for this repo
#     - "src/**/*.test.ts"      # additional test file pattern
#
#   # Label name remapping — use when this repo has custom workflow label names.
#   # Keys are canonical ForgeDock label names; values are the labels actually
#   # present in this repo. Agents apply this map to all gh issue edit calls:
#   label_map:
#     "workflow:investigating": "needs-triage"   # repo uses custom label name
#     "workflow:building":      "in-progress"
#
#   # Commit message style convention for this repo.
#   # Used by Phase 3M (commit) to format commit messages.
#   # Values: "conventional" | "conventional-with-scope" | "plain"
#   commit_style: "conventional-with-scope"
#
#   # Metadata written by the pipeline when this section was last updated:
#   captured_at: "2026-03-15T10:30:00Z"  # ISO 8601 timestamp
#   captured_by: "work-on/667"           # command + issue number that wrote it

# =============================================================================
# INDEX (OPTIONAL)
# Per-commit code index configuration for scripts/code-index.sh.
# When configured, agents query a deterministic symbol index and import graph
# instead of re-scanning the repo from scratch on every investigation, architect,
# and review run. Index is cached by HEAD SHA — zero cost on unchanged HEAD.
#
# Commands that use the index: work-on:investigate, work-on/build/architect,
#                              review-pr (domain agent context injection)
# =============================================================================

# index:
#   # Languages to extract symbols from. Passed to ctags --languages= flag.
#   # Omit to let ctags auto-detect. Example: Python, JavaScript, TypeScript, Go, Rust
#   # languages: "Python,JavaScript,TypeScript,Go"
#
#   # Glob patterns to exclude from indexing (relative to repo root).
#   # Added to the find/ctags exclude list alongside built-in defaults
#   # (.git, node_modules, __pycache__, .forge).
#   # exclude:
#   #   - "vendor/**"
#   #   - "dist/**"
#   #   - "**/*.min.js"
#
#   # Directory where the index cache is stored, relative to the project root.
#   # Default: ".forge/index" — gitignored by default (add .forge/ to .gitignore).
#   # Set to an absolute path to share the cache across multiple worktrees.
#   # cache_dir: ".forge/index"
#
#   # When true, the index is rebuilt automatically at the start of each
#   # investigation/architect/review run (cache-hit on unchanged HEAD = instant).
#   # When false, agents skip index queries and use grep exploration.
#   # Default: true
#   # enabled: true

# =============================================================================
# ATTRIBUTION (OPTIONAL)
# Opt-in growth features: pipeline-created PRs and visible FORGE annotation
# comments can carry a small attribution link back to ForgeDock.
# This is the "Dependabot/Renovate/CodeRabbit" growth mechanic — consentful
# and fully opt-out. Recommended default: both keys true for public repos,
# both false for private repos.
#
# Commands: work-on/review (PR footer), review-pr (summary comment footer),
#           work-on/investigate + review-pr agents (annotation link)
#
# Scope: PR body and visible comments only. Commits and machine-readable
# HTML annotation comments (<!-- FORGE:... -->) are NEVER modified.
# =============================================================================

# attribution:
#   # When true, every pipeline-created PR ends with exactly one muted footer:
#   #   > ⚒️ Orchestrated with [ForgeDock](https://github.com/RapierCraftStudios/ForgeDock)
#   #   > — state, scheduling, review, and memory on GitHub.
#   # Posted once at PR creation — never duplicated on edits or retries.
#   # Opt-out: set to false or omit this key.
#   # Recommended: true for public repos, false for private repos.
#   pr_footer: true
#
#   # When true, visible (human-readable) FORGE annotation comments — the ones
#   # displayed in the GitHub UI — carry a small "Pipeline powered by ForgeDock"
#   # link at the end. Machine-readable <!-- FORGE:... --> HTML comments are
#   # never modified regardless of this setting.
#   # Opt-out: set to false or omit this key.
#   # Recommended: true for public repos, false for private repos.
#   annotation_link: true

# =============================================================================
# PATTERN_FEEDS (OPTIONAL)
# Subscribe to external pattern card repositories so that validated learnings
# from one ForgeDock installation flow into this repo's ledger as low-priority
# priors. Patterns are fetched at a pinned ref — no floating-HEAD supply-chain
# surface. Imported cards are marked by origin and never counted toward local
# promotion thresholds (#1739 counts local validated findings only).
#
# How it works:
#   1. Run `node scripts/build-knowledge-index.mjs` (or add to CI) to pull
#      subscribed cards into the local ledger as LOW-priority priors.
#   2. Cards with a `gate.d` check template are seeded as Tier-B (warning)
#      learned rules in /quality-gate Step 2S for matching stacks.
#   3. Local validated findings always outrank imported cards by slug.
#   4. Unsubscribing removes all cards from that feed (tracked by origin tag).
#
# Security constraints:
#   - ALWAYS use a pinned commit SHA for `ref` — never `main` or `HEAD`.
#     Pinned refs prevent supply-chain injection from upstream changes.
#   - Imported cards are READ-ONLY inputs to the local ledger; they are never
#     executed, committed, or auto-published from your repo.
#   - The contribution path (/optimize Phase 5) requires explicit human
#     approval before anything flows OUTBOUND to an exchange repo.
#
# Commands: scripts/build-knowledge-index.mjs (pull), /quality-gate Step 2S
#           (seed gate rules), /optimize Phase 5 (contribution path)
# =============================================================================

# pattern_feeds:
#   # List of exchange repos to subscribe to.
#   # Each entry is a pinned-ref subscription to a public pattern card repo.
#   feeds:
#     - slug: "forge-core"
#       # GitHub repo containing the pattern cards (owner/repo format)
#       repo: "RapierCraftStudios/forge-patterns"
#       # REQUIRED: pinned commit SHA — never "main", "HEAD", or a branch name.
#       # Pinned refs prevent supply-chain injection from upstream changes.
#       # Update this SHA manually after reviewing the upstream diff.
#       ref: "abc1234def5678..."        # TODO: replace with actual commit SHA
#       # Path prefix within the repo where card files live.
#       # Cards are discovered as {path}/**/*.md files.
#       path: "cards"
#       # Stack filter — only import cards whose `stacks:` field overlaps
#       # with this list. Omit to import all cards regardless of stack.
#       # Valid values: node, python, bash, gha, typescript, go, rust, generic
#       stacks: ["node", "bash", "gha"]
#       # Priority assigned to all imported cards from this feed.
#       # LOW = imported cards are advisory priors; they never outrank local
#       # validated findings and never count toward promotion thresholds.
#       # Do not change this value — the pipeline enforces LOW for all feeds.
#       priority: "LOW"               # read-only: always LOW for imported cards
#
#     # Additional feeds — add more entries following the same schema:
#     # - slug: "my-team-patterns"
#     #   repo: "my-org/my-pattern-cards"
#     #   ref: "abc1234..."
#     #   path: "patterns"
#     #   stacks: ["python"]
#     #   priority: "LOW"
#
#   # When true, build-knowledge-index.mjs fetches all feeds and merges cards.
#   # When false, the script is a no-op (useful to temporarily disable without
#   # removing feed config).
#   enabled: true
#
#   # Local ledger path where imported cards are merged.
#   # Default: ".forge/ledger" — must match index.cache_dir if configured.
#   # ledger_path: ".forge/ledger"
