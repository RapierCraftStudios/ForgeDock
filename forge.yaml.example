# forge.yaml — ForgeDock Configuration
#
# Copy this file to forge.yaml in your project root and customize it.
# ForgeDock commands read forge.yaml to replace hardcoded project references
# with your project's actual values.
#
# Usage:
#   cp forge.yaml.example forge.yaml
#   # Edit forge.yaml with your project details
#   # Add forge.yaml to your .gitignore if it contains sensitive paths
#
# Required sections: project, paths, branches
# Optional sections: repos, project_board, services, review, verification, deploy, billing, devdocs, adaptive_scripts, learned, marketing

# =============================================================================
# PROJECT (REQUIRED)
# Core identity of your project. Used by all commands that interact with GitHub.
# Commands: work-on, review-pr, orchestrate, issue, milestone, cleanup
# =============================================================================

project:
  # Human-readable project name (used in reports and comments)
  name: "Acme Platform"

  # GitHub organization or username that owns the repository
  # Used as the --owner flag in gh project commands
  owner: "acme-org"

  # GitHub repository name (without the owner prefix)
  # Combined with owner to form GH_REPO: "acme-org/acme-platform"
  repo: "acme-platform"

  # One-line description of what this project does
  # Used in issue templates and pipeline reports
  description: "SaaS platform for automated data processing"

  # Personal GitHub login of the person who controls this project.
  # Used by work-on Phase 1D (correction capture) to filter issue comments
  # for owner-specific correction signals (e.g. "no, use staging not develop").
  #
  # When to set this:
  #   - REQUIRED for org-owned repos: GitHub comment .user.login is always a
  #     personal account (e.g. "mrdubey"), never the org name (e.g. "acme-org").
  #     Without this field, correction capture is silently disabled for org repos.
  #   - Optional for personal repos: omit it and the pipeline will auto-resolve
  #     via `gh api repos/{GH_REPO} --jq '.owner.login'`.
  #
  # Example (org repo owned by "acme-org", controlled by "alice"):
  #   owner_login: "alice"
  # owner_login: "alice"

  # Pipeline repository — optional. Set this if the ForgeDock pipeline itself
  # lives in a different repo than the project being developed.
  # Used by audit.md, audit-agents.md, and security-audit.md to resolve {FORGE_REPO}
  # when looking up pipeline issues, commands, and audit history.
  # If omitted, these commands fall back to project.owner/project.repo.
  # forge_repo: "acme-org/acme-forge"

# =============================================================================
# PATHS (REQUIRED)
# Local filesystem paths. Used by commands that create worktrees and read files.
# Commands: work-on (Phase 3E worktree creation), quality-gate, deploy-info
# =============================================================================

paths:
  # Absolute path to the project root on the local machine
  # This is where `git worktree add` commands are anchored
  root: "/home/youruser/projects/acme-platform"

  # Directory where git worktrees are created for each branch
  # Relative to root, or absolute path
  # Default: "{root}/.claude/worktrees"
  worktree_base: "/home/youruser/projects/acme-platform/.claude/worktrees"

  # Path to a credentials YAML file for external service authentication
  # Optional — only needed for commands that access analytics, monitoring, etc.
  # File should NOT be committed to version control
  # credentials:
  #   file: "/home/youruser/credentials.yaml"

# =============================================================================
# BRANCHES (REQUIRED)
# Branch naming conventions. Used to determine PR targets and source branches.
# Commands: work-on (PR targeting), review-pr, cleanup
# =============================================================================

branches:
  # Default branch of the repository (usually main or master)
  default: "main"

  # Staging branch name for fast-lane PRs (issues without a milestone)
  # Set to "main" if your project has no staging branch
  staging: "staging"

  # Pattern for feature/milestone branches
  # {slug} is replaced with the milestone title converted to kebab-case
  # Example: milestone "User Auth v2" → "milestone/user-auth-v2"
  feature_pattern: "milestone/{slug}"

# =============================================================================
# REPOS (OPTIONAL)
# Multi-repo configuration. Used when your project spans multiple repositories.
# Commands: work-on (multi-repo prefix routing), sync-ecosystem
#
# Without this section, all issues are routed to project.owner/project.repo.
# With this section, you can use prefixes like "mcp:5" or "n8n:12" to route
# issues to satellite repositories.
# =============================================================================

# repos:
#   # The default repository (same as project.owner/project.repo)
#   # Issues without a prefix are routed here
#   default:
#     repo: "acme-org/acme-platform"
#     staging_branch: "staging"
#
#   # Satellite repositories, keyed by prefix
#   # Format: "<prefix>:<issue_number>" in work-on commands
#   satellites:
#     - prefix: "mcp"
#       repo: "acme-org/acme-mcp-server"
#       staging_branch: "main"
#       local_path: "/home/youruser/projects/acme-mcp-server"
#
#     - prefix: "sdk"
#       repo: "acme-org/acme-python-sdk"
#       staging_branch: "main"
#       local_path: "/home/youruser/projects/acme-python-sdk"
#       # Set billing_enabled: true to run Phase 4 (Financial Integrity) of
#       # /security-audit against this satellite repo. Mirrors the top-level
#       # billing.enabled flag but scoped per-satellite.
#       # billing_enabled: false
#
#     # Monorepo satellite: multiple packages in a single repo.
#     # Use subpaths to name each package root relative to local_path.
#     # /sync-ecosystem uses these to locate per-package version files and
#     # publish workflows when syncing API changes across SDK packages.
#     - prefix: "mono"
#       repo: "acme-org/acme-sdks"
#       staging_branch: "main"
#       local_path: "/home/youruser/projects/acme-sdks"
#       subpaths:
#         python_sdk: "sdk/python"
#         node_sdk: "sdk/node"

# =============================================================================
# PROJECT BOARD (OPTIONAL)
# GitHub Projects (v2) integration. Used to track issue workflow state on the
# project board automatically as issues move through the pipeline.
# Commands: work-on (Phase 0C sync, Phase 6B update), orchestrate
#
# To find your project_id and field IDs:
#   gh project list --owner <owner>
#   gh project field-list <project_number> --owner <owner>
# =============================================================================

# project_board:
#   # GitHub organization or username that owns the project board
#   owner: "acme-org"
#
#   # Project number (visible in the URL: /projects/1)
#   project_number: 1
#
#   # GraphQL node ID of the project (PVT_... format)
#   # Run: gh project list --owner <owner> --format json | jq '.projects[] | {number, id}'
#   project_id: "PVT_kwHOxxxxxxxxxxxxxxxx"
#
#   # GitHub Projects field IDs (PVTSSF_... format)
#   # Run: gh project field-list <number> --owner <owner> --format json
#   field_ids:
#     status: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     lane: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     component: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     priority: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#     workflow: "PVTSSF_xxxxxxxxxxxxxxxxxxxxxxxx"
#
#   # Single-select option IDs for each field
#   # Run: gh project field-list <number> --owner <owner> --format json --jq '.fields[]'
#   option_ids:
#     status:
#       todo: "xxxxxxxx"
#       in_progress: "xxxxxxxx"
#       done: "xxxxxxxx"
#
#     lane:
#       fast: "xxxxxxxx"
#       feature: "xxxxxxxx"
#       sync: "xxxxxxxx"
#
#     priority:
#       p0: "xxxxxxxx"
#       p1: "xxxxxxxx"
#       p2: "xxxxxxxx"
#       p3: "xxxxxxxx"
#
#     workflow:
#       investigating: "xxxxxxxx"
#       building: "xxxxxxxx"
#       in_review: "xxxxxxxx"
#       merged: "xxxxxxxx"
#
#   # Component options map repo identifiers to option IDs
#   # Used to set the Component field when an issue is added to the board
#   components:
#     - repo: "acme-org/acme-platform"
#       option_id: "xxxxxxxx"
#       label: "Platform"
#     - repo: "acme-org/acme-mcp-server"
#       option_id: "xxxxxxxx"
#       label: "MCP Server"

# =============================================================================
# SERVICES (OPTIONAL)
# External service URLs and identifiers. Used by analytics, monitoring, and
# GEO audit commands.
# Commands: analytics, geo-audit, autopilot (analytics snapshot)
# =============================================================================

# services:
#   # Primary domain of the project's public-facing site
#   domain: "acme.io"
#
#   # Google Search Console property (full URL or domain: prefix)
#   gsc_property: "https://acme.io"
#
#   analytics:
#     # Umami self-hosted analytics
#     umami:
#       url: "https://umami.acme.io"
#       # Website ID from Umami dashboard
#       website_id: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
#     # Microsoft Clarity
#     clarity:
#       project_id: "xxxxxxxxxx"
#
#     # Persistent audit history file (YAML list of past audit snapshots)
#     # Written by /analytics after each run; read by Phase 0 for trend baselines
#     # Should be outside the repo — do not commit
#     # history_file: "/home/youruser/analytics-history.yaml"
#
#     # Google Analytics 4
#     ga4:
#       # GA4 property ID (numeric, from GA4 dashboard → Admin → Property Details)
#       property_id: "000000000"
#       # Path to a GA4 service account JSON key file
#       # Grant this service account Viewer access in GA4 → Admin → Account Access Management
#       # File should NOT be committed to version control
#       # service_account_key: "/home/youruser/credentials/ga4-service-account.json"
#
#   # Frontend app URL used by qa-sweep for page accessibility testing
#   # Default: http://localhost:3000 — override for non-localhost deployments
#   app_url: "https://acme.io"
#
#   # API base URL for health checks and endpoint verification
#   api_url: "https://api.acme.io"
#
#   # SSH target for production server health checks run by /autopilot
#   # Format: user@host — e.g., ubuntu@203.0.113.42
#   # Used in Phase 1 (SSH health check) of the autopilot cycle
#   # Optional — omit if autopilot does not need server-level checks
#   # server_ssh: "ubuntu@203.0.113.42"
#
#   # Absolute path on the production server to open eMemo files
#   # Used by /autopilot to surface in-progress work notes from the server
#   # Optional — only relevant if your team uses eMemo
#   # ememo_path: "/home/ubuntu/ememo"

# =============================================================================
# REVIEW (OPTIONAL)
# Context provided to review agents when they audit PRs.
# Commands: review-pr, review-pr-agents (all domain agents)
# =============================================================================

# review:
#   # Tech stack description — injected into review agent prompts
#   # Be specific: framework versions, DB engines, hosting environment
#   tech_stack: "Next.js 15 App Router, FastAPI, PostgreSQL 16, Docker, Traefik"
#
#   # Additional context for reviewers
#   # What makes this codebase unusual? What pitfalls exist?
#   context: |
#     Multi-service monorepo: services/api (Python/FastAPI), web/ (Next.js).
#     Deploy: blue/green via Docker Compose on a single VPS behind Traefik.
#     Database: PostgreSQL with async SQLAlchemy. No ORM migrations — raw SQL.
#
#   # Domain-specific review notes (keyed by review-pr-agents domain)
#   domains:
#     billing: "Stripe webhooks; idempotency keys required on all handlers"
#     auth: "JWT + refresh token rotation; sessions stored in Redis"
#     database: "Always use docker exec <container> for psql/migrations"
#
#   # Domain-to-file mapping used by /work-on investigation and /review-pr agents
#   # to quickly locate relevant files for a given issue domain.
#   # Keys match issue label domain names; values are lists of file path patterns
#   # (relative to repo root, glob-style). Optional — if omitted, agents infer
#   # relevant files from issue labels and the Affected Files section instead.
#   # key_paths:
#   #   auth: ["services/api/auth/**", "web/src/lib/auth/**"]
#   #   billing: ["services/api/billing/**", "web/src/app/billing/**"]
#   #   database: ["services/api/db/**", "migrations/**"]
#
#   # Layout paths used by pipeline commands for file discovery and classification.
#   # These drive /qa-sweep page discovery, /deploy-info file categorization,
#   # /orchestrate high-fan-in detection, /review-pr route-registration checks,
#   # and the verify-route-registration.sh script. All values are relative to
#   # the repository root. Defaults match the AlterLab monorepo layout — set
#   # these if your project uses a different directory structure.
#   #
#   # layout:
#   #   # Root directory of Next.js App Router pages (contains page.tsx / page.js files).
#   #   # Used by /qa-sweep to discover pages. Agent fails loudly if zero pages are
#   #   # found here and this key is not set.
#   #   pages: "web/src/app"
#   #
#   #   # Root directory of the backend API service.
#   #   # Used by /deploy-info file categorization and /review-pr integration checks.
#   #   api: "services/api"
#   #
#   #   # Directory containing FastAPI router modules (.py files).
#   #   # Used by /review-pr and verify-route-registration.sh to check router registration.
#   #   api_routers: "services/api/app/routers"
#   #
#   #   # Path to the API application entrypoint (router/middleware registration).
#   #   # High-fan-in file: /orchestrate serializes any issue that touches this file.
#   #   api_main: "services/api/app/main.py"
#   #
#   #   # Directory containing API middleware modules.
#   #   # Used by /review-pr and verify-route-registration.sh.
#   #   api_middleware: "services/api/app/middleware"
#   #
#   #   # Root directory of the background worker service.
#   #   # Used by /deploy-info file categorization and /orchestrate high-fan-in detection.
#   #   worker: "services/worker"
#   #
#   #   # Path to the worker service entrypoint (task registration, consumer setup).
#   #   # High-fan-in file: /orchestrate serializes any issue that touches this file.
#   #   worker_main: "services/worker/worker/main.py"
#   #
#   #   # Directory containing database migration files.
#   #   # Used by /deploy-info to detect and list migration changes.
#   #   migrations: "infra/migrations"
#   #
#   #   # Root directory of shared frontend component library.
#   #   # Used by verify-route-registration.sh to check component import coverage.
#   #   frontend_components: "web/src/components"

# =============================================================================
# VERIFICATION (OPTIONAL)
# Service health-check patterns for the quality gate and validate commands.
# Commands: quality-gate, validate
# =============================================================================

# verification:
#   # HTTP endpoint that returns 200 when the service is healthy
#   health_endpoint: "https://api.acme.io/health"
#
#   # Patterns to verify in the health response body
#   health_patterns:
#     - '"status": "ok"'
#     - '"database": "connected"'
#
#   # Services to check as part of deployment verification
#   services:
#     - name: "api"
#       container: "acme-api-blue"
#       health_url: "http://localhost:8000/health"
#     - name: "web"
#       container: "acme-web-blue"
#       health_url: "http://localhost:3000"
#
#   # Project-specific service name prefixes that identify internal services
#   # in shell scripts (curl/wget calls). Used by verify-host-headers.sh via
#   # the FORGE_INTERNAL_PATTERNS env var. Values are joined with | and appended
#   # to the generic defaults (localhost, 127.0.0.1, api-, worker-, 172.x, IP vars).
#   # Add your project's container/service name prefixes here so that curl calls
#   # to those services are checked for explicit Host headers.
#   # Example: if your services are named "acme-api", "acme-worker", add "acme-"
#   internal_service_patterns:
#     - "acme-"
#
#   # Toolchain commands for lint, format, typecheck, test, and build steps.
#   # Used by: review-pr, review-pr-staging, work-on (Phase 3H, validate), rollback,
#   #          incident-response, orchestrate (integration build gate).
#   #
#   # Declare your project's actual toolchain here once. Pipeline stages read these
#   # values and run your commands directly — they never assume poetry/npm/tsc.
#   # When a key is absent or empty, the stage logs "SKIPPED — not configured in
#   # verification.commands" and continues without failing. This means you can adopt
#   # the schema incrementally: add only the steps your project actually uses.
#   #
#   # Each command is a shell string run from the repository root (or the worktree
#   # root). Use relative paths or rely on $PATH. Commands may include flags.
#   #
#   # Language keys are arbitrary identifiers — name them after your stack.
#   # Common keys: python, typescript, go, rust, java, node
#   #
#   # commands:
#   #   # Python project using ruff + pytest
#   #   python:
#   #     format: "ruff format --check ."
#   #     lint: "ruff check ."
#   #     typecheck: "mypy src/ --ignore-missing-imports"
#   #     test: "pytest tests/ -x -q --tb=short"
#   #     build: ""   # omit or leave empty to skip
#   #
#   #   # TypeScript project using tsc + vitest
#   #   typescript:
#   #     format: "prettier --check \"src/**/*.{ts,tsx}\""
#   #     lint: "eslint src/"
#   #     typecheck: "tsc --noEmit"
#   #     test: "vitest run"
#   #     build: "npm run build"
#   #
#   #   # Go project
#   #   go:
#   #     format: "gofmt -l ."
#   #     lint: "golangci-lint run"
#   #     typecheck: ""   # Go compilation is the typecheck — set build instead
#   #     test: "go test ./..."
#   #     build: "go build ./..."
#   #
#   #   # Rust project
#   #   rust:
#   #     format: "cargo fmt --check"
#   #     lint: "cargo clippy -- -D warnings"
#   #     typecheck: ""
#   #     test: "cargo test"
#   #     build: "cargo build"

# =============================================================================
# DEPLOY (OPTIONAL)
# Deployment model configuration. Used by deploy-info, incident-response,
# rollback, and work-on to trigger and verify deploys without hardcoding
# workflow names, secrets chains, or container naming conventions.
# Commands: deploy-info, incident-response, rollback, work-on (Phase 3J)
# =============================================================================

# deploy:
#   # Filename of the GitHub Actions workflow used to trigger deploys.
#   # Referenced as: gh workflow run {deploy.workflow} --ref {branch} -f ...
#   # Set to "" or omit to skip workflow-trigger steps (CI/CD deploys automatically).
#   # Example: "hotfix-deploy.yml", "deploy.yml", "release.yml"
#   workflow: "hotfix-deploy.yml"
#
#   # Input parameter names for the deploy workflow.
#   # Keys are semantic names used by pipeline commands; values are the actual
#   # workflow_dispatch input names declared in the workflow file.
#   # Omit fields whose workflow does not declare the corresponding input.
#   workflow_inputs:
#     # Which services to rebuild/restart (comma-separated or "all")
#     services: "services"
#     # Human-readable deploy reason logged by the workflow
#     reason: "reason"
#
#   # Secrets backend used to deliver runtime secrets to containers.
#   # Controls which secret-chain checks run in work-on (Phase 3J) and deploy-info.
#   # Values:
#   #   sops     — Mozilla SOPS + decrypt-secrets.sh → .env.production chain
#   #   aws-sm   — AWS Secrets Manager (verification steps skipped — configure separately)
#   #   vault    — HashiCorp Vault (verification steps skipped — configure separately)
#   #   ci-env   — Secrets injected directly by CI/CD runner environment variables
#   #   none     — No secrets backend; all vars are operator-set in .env.production
#   # Default: none (all secret-chain checks are skipped with an explicit log message)
#   secrets_backend: "sops"

# =============================================================================
# BILLING (OPTIONAL)
# Controls whether financial integrity checks run in security-audit.md.
# Only relevant if your project uses Stripe or similar billing infrastructure.
# Commands: security-audit (Phase 4 — Financial Integrity)
# =============================================================================

# billing:
#   # Set to true to enable Phase 4 (Financial Integrity) in /security-audit.
#   # When false (default), the billing audit phase is skipped — appropriate for
#   # projects that do not process payments or have no Stripe integration.
#   enabled: false

# =============================================================================
# DEVDOCS (OPTIONAL)
# Path configuration for the devdocs knowledge tree scaffolded by
# `npx forgedock docs init`. Pipeline agents (work-on, review-pr, etc.) read
# these files as authoritative project knowledge before acting.
# Commands: docs init
# =============================================================================

# devdocs:
#   # Path to the devdocs knowledge tree, relative to the project root.
#   # Default: "devdocs" — creates devdocs/ in the project root.
#   # Run `npx forgedock docs init` to scaffold the tree from seed templates.
#   path: "devdocs"
#
#   # Migration note: if you previously stored project context in
#   # forge.yaml → review.context, move that content into the appropriate
#   # devdocs file:
#   #   - Architecture decisions  → devdocs/project/architecture.md
#   #   - Tech stack details      → devdocs/project/stack.md
#   #   - Coding conventions      → devdocs/project/conventions.md
#   #   - Project terminology     → devdocs/project/glossary.md
#   #   - ForgeDock usage notes   → devdocs/agent/using-forgedock.md
#   # Agents read devdocs/ files as binding source-of-truth, so they receive
#   # richer context than the single review.context string.

# =============================================================================
# ADAPTIVE_SCRIPTS (OPTIONAL)
# Per-repo scripts that ForgeDock generates and updates as it learns your
# project's patterns. These scripts live in .forgedock/scripts/ and take
# precedence over universal scripts shipped with ForgeDock.
#
# The directory is scaffolded automatically by `npx forgedock init` and is
# gitignored by default. Remove the .forgedock/scripts/ line from .gitignore
# to commit scripts to version control and share them with your team.
#
# Commands: work-on (script discovery), optimize (script generation — #668)
# =============================================================================

# adaptive_scripts:
#   # Enable or disable per-repo adaptive scripts.
#   # When false, pipeline agents use only universal scripts shipped with ForgeDock.
#   # Default: true
#   enabled: true
#
#   # Directory where per-repo scripts are stored, relative to the project root.
#   # Scaffolded by `npx forgedock init` if it doesn't exist.
#   # Default: ".forgedock/scripts"
#   directory: ".forgedock/scripts"
#
#   # Whether per-repo scripts are committed to version control.
#   # false (default): .forgedock/scripts/ is gitignored — scripts are local only
#   # true: remove .forgedock/scripts/ from .gitignore to share scripts with your team
#   # To opt in: remove the .forgedock/scripts/ entry from .gitignore
#   commit: false

# =============================================================================
# LEARNED (OPTIONAL)
# Agent-writable section for project-specific patterns captured across sessions.
# Pipeline agents read this section at startup (Phase 0B) and use it to override
# default routing decisions and toolchain commands. Agents write to this section
# when they detect correction signals in owner comments (Phase 1D).
#
# You can also edit this section manually after reviewing what agents have learned.
#
# All keys are optional — omit any key to use the pipeline default.
# Commands: work-on (Phase 0B reads; Phase 1D writes)
# =============================================================================

# learned:
#   # Branch target overrides — keyed by branch role, value is the actual branch name.
#   # These override branches.staging and similar fields when present.
#   # Example: if your project uses "develop" as the integration branch instead of "staging":
#   branch_targets:
#     staging: "develop"        # overrides branches.staging for fast-lane PR targeting
#
#   # Custom test commands to run during Phase 3H (validate) in addition to
#   # verification.commands entries. Appended to the verification step, not replaced.
#   # Use when the agent has learned repo-specific pre-PR checks:
#   test_commands:
#     - "pnpm typecheck"        # run before PR
#     - "pnpm test --run"
#
#   # Test location hints — overrides default assumption of tests/ directory.
#   # Used by Phase 3F to locate tests when writing or updating test files:
#   test_locations:
#     - "__tests__/"            # actual test directory for this repo
#     - "src/**/*.test.ts"      # additional test file pattern
#
#   # Label name remapping — use when this repo has custom workflow label names.
#   # Keys are canonical ForgeDock label names; values are the labels actually
#   # present in this repo. Agents apply this map to all gh issue edit calls:
#   label_map:
#     "workflow:investigating": "needs-triage"   # repo uses custom label name
#     "workflow:building":      "in-progress"
#
#   # Commit message style convention for this repo.
#   # Used by Phase 3M (commit) to format commit messages.
#   # Values: "conventional" | "conventional-with-scope" | "plain"
#   commit_style: "conventional-with-scope"
#
#   # Metadata written by the pipeline when this section was last updated:
#   captured_at: "2026-03-15T10:30:00Z"  # ISO 8601 timestamp
#   captured_by: "work-on/667"           # command + issue number that wrote it

# =============================================================================
# MARKETING (OPTIONAL)
# Controls opt-in growth features such as 'Powered by ForgeDock' footers on
# PR descriptions created by the pipeline.
# Commands: work-on (Phase 4 PR creation — when pr_footer is true)
# NOTE: pr_footer injection requires future pipeline support. Set to true
# to opt in once that support ships. Defaults to false (no-op).
# =============================================================================

# marketing:
#   # When true, the pipeline appends a small 'Powered by ForgeDock' footer to
#   # every PR description it creates. Opt-in only — set false to disable.
#   # This is a one-line footer link, not a banner. Example:
#   #   ---
#   #   *Powered by [ForgeDock](https://github.com/RapierCraftStudios/ForgeDock)*
#   pr_footer: false
